---
// Navbar.astro
---

<nav
  class="fixed w-full z-50 top-0 left-0 bg-brand-dark/80 backdrop-blur-md border-b border-brand-neon/20 px-4 py-3 sm:py-4"
>
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <!-- Brand / Logos -->
    <div class="flex items-center gap-3">
      <div class="text-2xl font-anton tracking-wider text-white">
        KIKE <span class="text-brand-neon">APUESTAS</span>
      </div>
      <div
        class="hidden sm:flex items-center gap-4 ml-6 border-l border-white/20 pl-6"
      >
        <!-- Social Icons (SVG) -->
        <a
          href="https://www.instagram.com/kikeapuestas/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-400 hover:text-brand-neon transition-colors duration-300"
          aria-label="Instagram"
        >
          <svg
            class="w-5 h-5"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"
              clip-rule="evenodd"></path>
          </svg>
        </a>
        <a
          href="https://www.youtube.com/@kikeapuestas"
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-400 hover:text-brand-neon transition-colors duration-300"
          aria-label="YouTube"
        >
          <svg
            class="w-5 h-5"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M19.812 5.418c.861.23 1.538.907 1.768 1.768C21.998 8.746 22 12 22 12s-.002 3.254-.42 4.814a2.504 2.504 0 0 1-1.768 1.768c-1.56.419-7.812.419-7.812.419s-6.252 0-7.812-.419a2.505 2.505 0 0 1-1.768-1.768C2 15.254 2 12 2 12s.002-3.254.42-4.814a2.507 2.507 0 0 1 1.768-1.768C5.748 5 12 5 12 5s6.252 0 7.812.418zM9.546 14.63l5.885-3.053-5.885-3.053v6.106z"
              clip-rule="evenodd"></path>
          </svg>
        </a>
        <a href="https://kick.com/kickeapuestas" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-brand-neon transition-colors duration-300" aria-label="Kick">
          <svg class="w-5 h-5 transform scale-[0.85]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M1.333 0h8v5.333H12V2.667h2.667V0h8v8H20v2.667h-2.667v2.666H20V16h2.667v8h-8v-2.667H12v-2.666H9.333V24h-8Z"/>
          </svg>
        </a>
        <a href="https://www.facebook.com/kikeapuesta" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-brand-neon transition-colors duration-300" aria-label="Facebook">
          <svg class="w-5 h-5 transform scale-[0.90]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Navigation Menu -->
    <ul
      class="hidden md:flex items-center gap-8 text-sm font-bold tracking-widest uppercase"
    >
      <li>
        <a
          href="#inicio"
          class="text-gray-300 hover:text-brand-neon transition-colors duration-300"
          >Inicio</a
        >
      </li>
      <li>
        <a
          href="#register"
          class="text-gray-300 hover:text-brand-neon transition-colors duration-300"
          >Registro</a
        >
      </li>
      <li>
        <a
          href="#bighits"
          class="text-gray-300 hover:text-brand-neon transition-colors duration-300"
          >Videos Destacados</a
        >
      </li>
    </ul>

    <!-- Mobile Menu Button (Hamburger) -->
    <div class="md:hidden flex items-center">
      <button id="mobile-btn" class="text-gray-300 hover:text-white" aria-label="Menu">
        <svg
          class="w-7 h-7"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 w-full bg-brand-dark/95 backdrop-blur-xl border-b border-brand-neon/20 shadow-2xl transition-all">
    <ul class="flex flex-col px-4 py-8 space-y-6 text-center text-sm font-bold tracking-widest uppercase">
      <li>
        <a href="#inicio" class="mobile-link block text-gray-300 hover:text-brand-neon transition-colors duration-300">Inicio</a>
      </li>
      <li>
        <a href="#register" class="mobile-link block text-gray-300 hover:text-brand-neon transition-colors duration-300">Registro</a>
      </li>
      <li>
        <a href="#bighits" class="mobile-link block text-gray-300 hover:text-brand-neon transition-colors duration-300">Videos Destacados</a>
      </li>
    </ul>
  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const mobileBtn = document.getElementById('mobile-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileLinks = document.querySelectorAll('.mobile-link');

    if (mobileBtn && mobileMenu) {
      mobileBtn.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
      });

      // Close menu when a link is clicked
      mobileLinks.forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
        });
      });
    }
  });
</script>
