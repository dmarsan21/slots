---
import { Image } from 'astro:assets';
import heroImage from '../assets/images/hero.png';
---

<header id="inicio" class="relative w-full min-h-screen flex items-center pt-24 overflow-hidden">
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
    <!-- Left Column: Copy -->
    <div class="text-left order-2 lg:order-1 flex flex-col items-center lg:items-start space-y-6 lg:py-16">
      
      <!-- Lucky Feather Badge -->
      <div class="inline-flex items-center gap-2 bg-black/40 border border-brand-teal/50 shadow-[0_0_15px_rgba(20,184,166,0.2)] rounded-full px-5 py-2 backdrop-blur-md self-center lg:self-start mb-2 group">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-teal group-hover:text-brand-neon transition-colors duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2C16 4 21 8 21 13C21 18 16 22 12 22C8 22 3 18 3 13C3 8 8 4 12 2Z"></path>
          <path d="M12 22V13"></path>
          <path d="M10 16L12 13"></path>
          <path d="M14 17L12 13"></path>
        </svg>
        <span class="text-sm font-bold text-white tracking-widest uppercase">La Pluma de la Suerte</span >
      </div>

      <h1 class="text-6xl sm:text-7xl lg:text-[5rem] font-anton text-white leading-[1.05] uppercase drop-shadow-2xl text-center lg:text-left tracking-tight">
        Bienvenido al Hub<br class="hidden sm:block" />
        <span class="text-gradient-neon">Más Exclusivo</span>
      </h1>
      
      <p class="text-lg sm:text-xl text-gray-300 max-w-xl text-center lg:text-left font-semibold leading-relaxed drop-shadow-md">
        ¡Bienvenido a la comunidad más extrema! Sígueme en mi canal de YouTube y no te pierdas mis transmisiones en vivo. Acompáñame en cada jugada, ríete con mis anécdotas, descubre mis estrategias de primera mano y vive la máxima tensión en tiempo real. La adrenalina de buscar el MAX WIN nunca se termina cuando juegas con El Tío Kike.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-6 pt-6 sm:justify-center lg:justify-start w-full">
        <a href="#register" class="w-full sm:w-auto text-center bg-brand-neon text-black font-extrabold text-xl px-10 py-5 rounded-xl uppercase tracking-widest hover-glow-neon transition-all duration-300 transform hover:scale-105 shadow-[0_0_20px_rgba(0,255,0,0.3)]">
          Comenzar la Acción
        </a>
      </div>
    </div>

    <!-- Right Column: Avatar -->
    <div class="order-1 lg:order-2 flex justify-center lg:justify-end relative h-[45vh] sm:h-[50vh] lg:h-[75vh]">
      <!-- Background subtle glow just behind the character -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2/3 h-2/3 bg-brand-teal/20 rounded-full blur-[100px] pointer-events-none"></div>
      
      <!-- Character Drawing Transparent Floating (Made smaller and contained) -->
      <div class="relative w-full h-full flex items-center justify-center drop-shadow-[0_20px_50px_rgba(0,0,0,0.8)] z-10 transition-transform duration-700 hover:scale-[1.02]">
        <Image 
          src={heroImage} 
          alt="El Tío Kike" 
          class="w-full h-full object-contain object-center drop-shadow-[0_0_25px_rgba(20,184,166,0.3)] p-4"
          width={1000}
          height={1200}
        />
      </div>
    </div>
  </div>
</header>
