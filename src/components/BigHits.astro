---
// BigHits.astro
import { Image } from 'astro:assets';
import yt1 from '../assets/images/youtube1.jpg';
import yt2 from '../assets/images/youtube2.jpg';
import yt3 from '../assets/images/youtube3.jpg';
import yt4 from '../assets/images/youtube4.jpg';
import yt5 from '../assets/images/youtube5.jpg';
import yt6 from '../assets/images/youtube6.jpg';

const videos = [
  {
    title: "¡¡MEGA DIAMANTE!! con un multi grande esto se puede ROMPER \"BANK BLAST\"",
    thumbnail: yt1,
    url: "https://www.youtube.com/@kikeapuestas",
    platform: "YouTube"
  },
  {
    title: "¡¡REMONTADA EPICA!! de estar a nada de perder, a ganarlo TODO",
    thumbnail: yt2,
    url: "https://www.youtube.com/@kikeapuestas",
    platform: "YouTube"
  },
  {
    title: "¡¡APOSTÉ $250,000 a KARELY RUIZ!! y esto fue lo que pasó después 😳",
    thumbnail: yt3,
    url: "https://www.youtube.com/@kikeapuestas",
    platform: "YouTube"
  },
  {
    title: "🔥 DE LA ZONA VIP… A REGALAR DINERO EN EL FESTIVAL TECATE PAL NORTE 2026 💸",
    thumbnail: yt4,
    url: "https://www.youtube.com/@kikeapuestas",
    platform: "YouTube"
  },
  {
    title: "¡¡LE TERCO LO HIZO DE NUEVO!! La más DURA de todas LE FISHERMAN de Hacksw Gaming",
    thumbnail: yt5,
    url: "https://www.youtube.com/@kikeapuestas",
    platform: "YouTube"
  },
  {
    title: "🔥¡¡¡MAX WIN!!!🔥YA NO TENÍA NADA Y PASÓ LO IMPOSIBLE… DRAGONSPIRE💰",
    thumbnail: yt6,
    url: "https://www.youtube.com/@kikeapuestas",
    platform: "YouTube"
  }
];
---

<section id="bighits" class="py-24 bg-black relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-4 mb-12">
      <div class="h-10 w-2 bg-brand-neon rounded-full"></div>
      <h2 class="text-4xl sm:text-5xl font-anton text-white uppercase tracking-wider">
        Mis <span class="text-brand-neon">Videos Destacados</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {videos.map(video => (
        <div class="flex flex-col h-full">
          <!-- Tarjeta principal -->
          <a 
            href={video.url} 
            target="_blank" 
            rel="noopener noreferrer" 
            class="group relative rounded-2xl overflow-hidden bg-gray-900 border border-white/10 hover:border-brand-neon transition-all duration-500 flex flex-col flex-grow"
          >
            <!-- Thumbnail Image -->
            <div class="relative block aspect-video w-full overflow-hidden shrink-0">
              <Image 
                src={video.thumbnail} 
                alt={video.title} 
                class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700 opacity-90 group-hover:opacity-100"
                width={600}
                height={338}
              />
              <!-- Dark overlay -->
              <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-colors duration-300"></div>
              
              <!-- Play Button Overlay -->
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-16 h-16 bg-[#FF0000]/90 text-white rounded-full flex items-center justify-center pl-1 transform group-hover:scale-110 group-hover:shadow-[0_0_20px_#FF0000] transition-all duration-300 backdrop-blur-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </div>
              </div>

              <!-- Platform Badge -->
              <div class="absolute top-4 left-4 bg-black/60 backdrop-blur-md px-3 py-1 rounded-full border border-white/10">
                <span class="text-xs font-semibold text-white uppercase tracking-wider">{video.platform}</span>
              </div>
            </div>

            <!-- Video Info -->
            <div class="p-5 flex flex-col flex-grow">
              <h3 class="text-lg font-bold text-white leading-snug line-clamp-2 group-hover:text-brand-neon transition-colors duration-300">
                {video.title}
              </h3>
              

            </div>
          </a>

          <!-- Share pill (independiente visualmente) -->
          <div class="mt-3 flex justify-end group/share">
            <div class="flex items-center gap-1.5 bg-white/5 backdrop-blur-sm border border-white/5 group-hover/share:border-brand-neon/50 transition-all duration-500 rounded-full pl-4 pr-1.5 py-1 shadow-lg">
              <span class="text-[10px] font-bold text-white/90 uppercase tracking-widest mr-1 mt-0.5">Compartir:</span>
              <!-- WhatsApp -->
              <a 
                href={`https://wa.me/?text=${encodeURIComponent('¡Mira este tremendo hit del Tío Kike! 🎰 ' + video.url)}`}
                target="_blank" 
                rel="noopener noreferrer" 
                class="text-brand-neon opacity-70 hover:opacity-100 hover:scale-110 transition-all duration-300 flex items-center justify-center min-w-[36px] min-h-[36px]"
                aria-label="Compartir en WhatsApp"
                title="Compartir en WhatsApp"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                  <path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"/>
                </svg>
              </a>
              
              <!-- X / Twitter -->
              <a 
                href={`https://twitter.com/intent/tweet?text=${encodeURIComponent('¡Checa este premio gordo en Stake! 🔥')}&url=${encodeURIComponent(video.url)}`}
                target="_blank" 
                rel="noopener noreferrer" 
                class="text-brand-neon opacity-70 hover:opacity-100 hover:scale-110 transition-all duration-300 flex items-center justify-center min-w-[36px] min-h-[36px]"
                aria-label="Compartir en X (Twitter)"
                title="Compartir en X"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                  <path d="M12.6.75h2.454l-5.36 6.142L16 15.25h-4.937l-3.867-5.07-4.425 5.07H.316l5.733-6.57L0 .75h5.063l3.495 4.633L12.601.75Zm-.86 13.028h1.36L4.323 2.145H2.865l8.875 11.633Z"/>
                </svg>
              </a>
              
              <!-- Facebook -->
              <a 
                href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(video.url)}`}
                target="_blank" 
                rel="noopener noreferrer" 
                class="text-brand-neon opacity-70 hover:opacity-100 hover:scale-110 transition-all duration-300 flex items-center justify-center min-w-[36px] min-h-[36px]"
                aria-label="Compartir en Facebook"
                title="Compartir en Facebook"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                  <path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951z"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <div class="text-center mt-12">
      <a href="https://www.youtube.com/@kikeapuestas" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-white hover:text-brand-neon transition-colors font-semibold uppercase tracking-wider text-sm">
        Ver más vídeos en YouTube
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </div>
</section>
